## Struktura pliku JS

```js
const STATES = { /* ... */ };
const FAN_MAP = { /* ... */ };
const MOP_INTENSITY_MAP = { /* ... */ };
const MOP_MODE_MAP = { /* ... */ };
const CONSUMABLES = [ /* ... */ ];
const ERROR_MAP = { /* ... */ };
const STATUS_GROUPS = { /* ... */ };
const ACCENT = { /* ... */ };
const BADGE_LABELS = { /* ... */ };
const DOCK_STATUS_LABELS = { /* ... */ };
const ACTIONS = [ /* ... */ ];

class RoboVacuumCard extends HTMLElement {
  constructor() {
    super();
    this.attachShadow({ mode: 'open' });
    this._mode = 'slim';
    this._hass = null;
    this._config = null;
    this._lastState = null;
    this._lastMode = null;
  }

  setConfig(config) {
    if (!config.entity) throw new Error('Wymagane: entity');
    this._config = config;
    this._mode = config.default_mode ?? 'slim';
  }

  set hass(hass) {
    this._hass = hass;
    const e = hass.states[this._config.entity];
    if (!e) return;
    const sig = e.state + JSON.stringify(e.attributes)
              + this._getSensorSig();
    if (sig === this._lastState && this._mode === this._lastMode) return;
    this._lastState = sig;
    this._lastMode = this._mode;
    this._render();
  }

  _getSensorSig() {
    // skrócony signature wszystkich czytanych sensorów
    const s = this._config.sensors ?? {};
    return Object.values(s).map(id => this._hass.states[id]?.state ?? '').join('|');
  }

  getCardSize() { return this._mode === 'slim' ? 1 : 5; }

  _toggleMode() {
    this._mode = this._mode === 'slim' ? 'verbose' : 'slim';
    this._lastMode = null;
    this.hass = this._hass;
  }

  _callService(domain, service, serviceData = {}) {
    this._hass.callService(domain, service, {
      entity_id: this._config.entity,
      ...serviceData,
    });
  }

  _getSensor(key) {
    const id = this._config.sensors?.[key];
    return id ? this._hass.states[id] : null;
  }

  _getBinarySensor(key) {
    const id = this._config.binary_sensors?.[key];
    return id ? this._hass.states[id] : null;
  }

  _getSelect(key) {
    const id = this._config.selects?.[key];
    return id ? this._hass.states[id] : null;
  }

  _render() {
    const html = this._mode === 'slim' ? this._renderSlim() : this._renderVerbose();
    this.shadowRoot.innerHTML = html;
    this._attachEventListeners();
  }

  _attachEventListeners() {
    this.shadowRoot.querySelector('.toggle-btn')?.addEventListener('click', e => {
      e.stopPropagation();
      this._toggleMode();
    });
    this.shadowRoot.querySelectorAll('.action-btn').forEach(btn => {
      btn.addEventListener('click', e => {
        e.stopPropagation();
        const [domain, service] = btn.dataset.service.split('.');
        this._callService(domain, service);
      });
    });
    // tap całej karty → more-info (tylko slim)
    if (this._mode === 'slim') {
      this.shadowRoot.querySelector('.card')?.addEventListener('click', () => {
        const event = new Event('hass-more-info', { bubbles: true, composed: true });
        event.detail = { entityId: this._config.entity };
        this.dispatchEvent(event);
      });
    }
  }

  _renderSlim() { /* ... */ }
  _renderVerbose() { /* ... */ }
  _renderDock() { /* ... */ }
  _renderConsumables() { /* ... */ }
  _renderActions() { /* ... */ }
  _renderStats() { /* ... */ }
}

customElements.define('roborock-vacuum-card', RoboVacuumCard);
window.customCards = window.customCards ?? [];
window.customCards.push({
  type: 'roborock-vacuum-card',
  name: 'Roborock Vacuum Card',
  description: 'Roborock Saros 10R — slim + verbose, z dokiem i suszeniem mopa',
});
```

