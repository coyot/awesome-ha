## Consumables — progi i jednostki

Konsumables dla Saros 10R są w **godzinach** (`device_class: duration`, `unit: h`):

```js
const CONSUMABLES = [
  { key: 'filter_left',     label: 'Filtr',         maxHours: 150,  warnAt: 30  },
  { key: 'main_brush_left', label: 'Szczotka gł.',  maxHours: 300,  warnAt: 60  },
  { key: 'side_brush_left', label: 'Szczotka bocz.',maxHours: 200,  warnAt: 40  },
  { key: 'sensor_left',     label: 'Czujnik',       maxHours: 30,   warnAt: 8   },
];

// Normaliza do % (0–100):
function consumablePct(hoursLeft, maxHours) {
  return Math.max(0, Math.min(100, (hoursLeft / maxHours) * 100));
}

// Kolor progu:
function cCol(pct) {
  if (pct <= 10) return '#E24B4A';   // czerwony — wymień
  if (pct <= 30) return '#EF9F27';   // żółty — wkrótce
  return '#97C459';                   // zielony — ok
}
```

